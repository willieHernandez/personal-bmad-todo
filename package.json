{
  "name": "todo-bmad-style",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm --filter client dev\" \"pnpm --filter server dev\"",
    "build": "pnpm --filter shared build && pnpm --filter client build && pnpm --filter server build",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:integration": "pnpm --filter server test:integration",
    "test:e2e": "E2E_OWN_SERVER=1 playwright test",
    "test:e2e:ui": "E2E_OWN_SERVER=1 playwright test --ui"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "@playwright/test": "^1.52.0",
    "concurrently": "^9.2.1",
    "vitest": "^3.2.4"
  }
}
